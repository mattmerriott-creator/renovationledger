# Copy to .env.local and fill in.

# Live sold comps by proximity. Free key (50 lookups/month): https://app.rentcast.io/app/api
# Without a key the comps page shows clearly-labeled sample data.
RENTCAST_API_KEY=

# Receipt scanning: reads vendor, date, and amount off receipt photos automatically.
# Get a key at https://platform.claude.com — usage-based, roughly a cent or two per scan.
# Without a key, receipts still attach to transactions; you just type the fields.
ANTHROPIC_API_KEY=

# Public URL of the site once deployed (used for SEO tags and sitemap)
SITE_URL=http://localhost:3000
